{
  "name": "kyo-web-online",
  "version": "2.0.0-vue-migration",
  "description": "Kyo's Personal Website — Vue 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:i18n-keys": "node scripts/check-i18n-keys.mjs",
    "check:trans": "node scripts/check-trans-attrs.mjs",
    "check:color": "node scripts/check-color-usage.mjs",
    "check:aliases": "node scripts/check-aliases.mjs",
    "check:licenses": "node scripts/check-license-headers.mjs",
    "precheck": "node scripts/precheck.mjs",
    "convert:fonts": "./scripts/convert-fonts.sh",
    "convert:fonts:subset": "./scripts/convert-fonts.sh --subset",
    "convert:images": "node scripts/convert-images.mjs",
    "convert:images:force": "node scripts/convert-images.mjs --force",
    "predev": "npm run convert:images -- --quiet",
    "prebuild": "npm run convert:images && npm run precheck",
    "generate-favicons": "grunt --force",
    "build-all": "npm-run-all --sequential generate-favicons build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kyonax/kyo-web-online.git"
  },
  "keywords": [
    "Kyonax",
    "kyo",
    "kyonax_on_tech",
    "kyo-wtf",
    "KYO-T",
    "京"
  ],
  "author": "Cristian Moreno (Kyonax)",
  "license": "GPL-2.0-only",
  "bugs": {
    "url": "https://github.com/Kyonax/kyo-web-online/issues"
  },
  "homepage": "https://github.com/Kyonax/kyo-web-online#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@unhead/vue": "^1.11.13",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "grunt": "^0.4.5",
    "grunt-favicons": "^0.8.0",
    "happy-dom": "^15.11.7",
    "npm-run-all": "^4.1.5",
    "sass": "^1.81.0",
    "sharp": "^0.34.5",
    "vite": "^6.0.7",
    "vite-plugin-beasties": "^0.4.2",
    "vite-plugin-html": "^3.2.2",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^9.4.3"
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "not dead"
  ]
}
