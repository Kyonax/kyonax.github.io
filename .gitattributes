#
# .gitattributes — Per-path encoding and EOL discipline
# 2026-05-14
#
# Pins Unicode glyph storage so Windows clones cannot apply
# CRLF + BOM rewrites that silently corrupt PUA or CJK
# codepoints. The pinned paths carry the hero kanji watermarks,
# Nerd Font glyph escapes, and Simple Icons brand SVGs.
#
#   Per-file pins (UTF-8 / LF)
#   Default repo-wide LF normalization
#
# Guidelines:
#   Use \uXXXX escapes in JS strings, never typed raw glyphs
#   Cross-reference: session SECTION 1.15

# ── Per-file pins (UTF-8 + LF) ───────────────────────────────
src/scss/abstracts/_theme.scss       text eol=lf working-tree-encoding=UTF-8
src/data/snippets.js                 text eol=lf working-tree-encoding=UTF-8
src/data/projects.js                 text eol=lf working-tree-encoding=UTF-8
src/views/components/sections/*.vue  text eol=lf working-tree-encoding=UTF-8
src/widgets/*.vue                    text eol=lf working-tree-encoding=UTF-8
src/i18n/*.js                        text eol=lf working-tree-encoding=UTF-8
src/assets/brands/*.svg              text eol=lf working-tree-encoding=UTF-8

# ── Repo-wide default ────────────────────────────────────────
* text=auto
